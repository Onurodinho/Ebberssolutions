{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ebbers",
  "main": "worker.js",
  "compatibility_date": "2026-06-22",
  "workers_dev": true,
  "observability": { "enabled": true },
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "not_found_handling": "404-page"
  }
}